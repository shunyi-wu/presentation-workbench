{
  "name": "presentation-workbench",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start:workbench": "node scripts/workbench-start.js",
    "open:workbench": "node scripts/workbench-start.js --open-only",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "verify:docs": "node scripts/verify-docs.js",
    "verify:slides": "npm run check && npm run review",
    "verify:full": "npm run verify:docs && npm run verify:slides && npm run build",
    "check": "playwright test tests/overflow.spec.js",
    "review": "playwright test tests/review.spec.js",
    "review:checkpoint": "node scripts/create-review-checkpoint.js",
    "clean:review": "node scripts/clean-review-current.js",
    "test:gallery": "playwright test tests/workbench-gallery.spec.js",
    "test": "npm run check && npm run test:gallery"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "vite": "^7.0.0"
  }
}
