{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Workbench",
      "type": "npm",
      "script": "start:workbench",
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "Starting Presentation Workbench|> presentation-workbench@.* start:workbench",
          "endsPattern": "Local:\\s+http://127\\.0\\.0\\.1:5174/"
        }
      },
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated",
        "clear": false
      }
    },
    {
      "label": "Open Workbench Desktop",
      "type": "npm",
      "script": "open:workbench",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "never",
        "panel": "shared"
      }
    }
  ]
}
